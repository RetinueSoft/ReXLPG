@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div ng-controller="UserLoginAccountController">
    <div class="row d-flex justify-content-center align-items-center">
        <div class="col-lg-4">
            <div>
                <div class="p-4">
                    <h3 class="text-uppercase text-center">Login</h3>

                    <div class="input-group mt-4" id="userMobileGroupLogin">
                        <div class="input-group-prepend">
                            <span class="input-group-text rem6dot5">Mobile</span>
                        </div>
                        <input id="mobilenumber" placeholder="Mobile Number" class="form-control" type="text" maxlength="10"
                               ng-model="user.mobile" oninput="this.value = this.value.replace(/[^0-9]/g, '').slice(0, 10)">
                    </div>

                    <div class="input-group mt-4" id="userPasswordGroupLogin">
                        <div class="input-group-prepend">
                            <span class="input-group-text rem6dot5">Password</span>
                        </div>
                        <input type="password" class="form-control" id="password" placeholder="Password" ng-model="user.password">
                    </div>
                    <div id='divet_loginerror' class="d-flex">
                        <small id='et_loginerror'></small>
                    </div>

                    <div class="d-flex justify-content-center mt-4">
                        <button type="button" class="btn btn-dark" id="userLoginBtn" ng-click="login()">
                            Login
                        </button>
                    </div>                    
                    <div class="row mt-1">
                        <div class="col-sm-12 col-md-7">
                            Enquiry / New? <a href="" ng-href="/Home/SignUp" class="fw-bold text-body"><u>Sign Up</u></a>
                        </div>
                        <div class="col-sm-12 col-md-5 text-md-end">
                            <a href="" ng-href="/Home/ForgotPassword" class="fw-bold text-body text-right"><u>Forgot Password</u></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>