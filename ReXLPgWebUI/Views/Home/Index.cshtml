<script>
    const texts = [
      {text:"<i class='fa-solid fa-kitchen-set' style='padding-right: 20px'></i> Make your own food or take a subscription", color:"#bdf0e1"},
      {text:"<i class='fa-solid fa-toolbox' style='padding-right: 20px'></i> Wi-Fi, Fridge, Washing Machine, 24/7 Power, CCTV", color:"#dfd3fa"},
      {text:"<i class='fa-solid fa-couch' style='padding-right: 20px'></i> Soft Mattresses, Study table and Full Furnished Room", color:"#dcd7df"},
      {text:"<i class='fa-solid fa-sliders' style='padding-right: 20px'></i> And more flexible options to fit your needs", color:"#fed3e3"},
      {text:"<i class='fa-solid fa-bed' style='padding-right: 20px'></i> Choose a shared space or pick a private room", color:"#ffebd1"}
    ];

    let index = 0;
    const box = document.getElementById('rotatingText');

    setInterval(() => {
      index = (index + 1) % texts.length;
      box.innerHTML  = texts[index].text;
      box.style.backgroundColor = texts[index].color;
    }, 3000); // Change every 3 seconds
</script>