@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div ng-controller="UserLoginAccountController">
    <div class="row d-flex justify-content-center align-items-center">
        <div class="col-lg-4">
            <div>
                <div class="p-4">
                    <h3 class="text-uppercase text-center mb-4">Sign Up</h3>

                    <div class="input-group" id="userNameGroupLogin">
                        <div class="input-group-prepend">
                            <span class="input-group-text rem6dot5">Name*</span>
                        </div>
                        <input id="nameUL" placeholder="Name" class="form-control" type="text" maxlength="30"
                               ng-model="user.name" oninput="this.value = this.value.replace(/[^a-zA-Z\s]/g, '')">
                    </div>
                    <div class="input-group mt-4" id="userMobileGroupLogin">
                        <div class="input-group-prepend">
                            <span class="input-group-text rem6dot5">Mobile*</span>
                        </div>
                        <input id="mobilenumber" placeholder="Mobile Number" class="form-control" type="text" maxlength="10"
                               ng-model="user.mobile" oninput="this.value = this.value.replace(/[^0-9]/g, '').slice(0, 10)">
                    </div>
                    <div class="input-group mt-4" id="userPasswordGroupLogin">
                        <div class="input-group-prepend">
                            <span class="input-group-text rem6dot5">Password*</span>
                        </div>
                        <input type="password" class="form-control" id="password" placeholder="Password" ng-model="user.password">
                    </div>
                    <div class="input-group mt-4" id="userConfirmPasswordGroupLogin">
                        <div class="input-group-prepend">
                            <span class="input-group-text rem6dot5">Confirm*</span>
                        </div>
                        <input type="password" class="form-control" id="cpassword" placeholder="Confirm Password" ng-model="user.cpassword">
                    </div>
                    <div class="input-group mt-4" id="userAadharGroupLogin">
                        <div class="input-group-prepend">
                            <span class="input-group-text rem6dot5">Aadhar</span>
                        </div>
                        <input id="aadharnumber" placeholder="Aadhar Number" class="form-control" type="text" maxlength="12"
                               ng-model="user.aadharNumber" oninput="this.value = this.value.replace(/[^0-9]/g, '').slice(0, 12)">
                    </div>
                    <div class="input-group mt-4" id="userSubMonthsGroupLogin">
                        <div class="input-group-prepend">
                            <span class="input-group-text">Duration Likes to Stay</span>
                        </div>
                        <input id="submonths" placeholder="In Months" class="form-control" type="text" maxlength="2"
                               ng-model="user.subscriptionMonths" oninput="this.value = this.value.replace(/[^0-9]/g, '').slice(0, 2)">
                    </div>
                    <div id='divet_loginerror' class="d-flex">
                        <small id='et_loginerror'></small>
                    </div>

                    <div class="d-flex justify-content-center mt-4">
                        <button type="button" class="btn btn-dark" id="userSignupBtn" ng-click="signup()">
                            Create Account
                        </button>
                    </div>
                    <div class="row mt-1">
                        <div class="col-sm-12 col-md-7">
                            Already have? <a href="" ng-href="/Home/Login" id="loginBtn" class="fw-bold text-body"><u>Login</u></a>
                        </div>
                        <div class="col-sm-12 col-md-5 text-md-end">
                            <a href="" ng-href="/Home/ForgotPassword" class="fw-bold text-body text-right"><u>Forgot Password</u></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>